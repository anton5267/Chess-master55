<div class="theme-switcher" role="group" aria-label="@Localizer["Theme_Label"]">
    <div class="theme-switcher-field">
        <label class="theme-switcher-label" for="site-theme-select">@Localizer["Theme_Label"]</label>
        <select id="site-theme-select" class="form-control form-control-sm theme-switcher-select theme-variant-select" aria-label="@Localizer["Theme_Label"]">
            <option value="auto">@Localizer["Theme_Auto"]</option>
            <option value="light">@Localizer["Theme_Light"]</option>
            <option value="dark">@Localizer["Theme_Dark"]</option>
            <option value="warm-dark">@Localizer["Theme_WarmDark"]</option>
            <option value="contrast-light">@Localizer["Theme_ContrastLight"]</option>
            <option value="contrast-dark">@Localizer["Theme_ContrastDark"]</option>
        </select>
    </div>

    <div class="theme-switcher-field">
        <label class="theme-switcher-label" for="site-motion-select">@Localizer["Motion_Label"]</label>
        <select id="site-motion-select" class="form-control form-control-sm theme-switcher-select theme-motion-select" aria-label="@Localizer["Motion_Label"]">
            <option value="on">@Localizer["Motion_On"]</option>
            <option value="off">@Localizer["Motion_Off"]</option>
        </select>
    </div>
</div>
