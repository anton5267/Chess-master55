@using System
@using System.Globalization
@using Chess.Common.Constants

@{
    var currentController = this.ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = this.ViewContext.RouteData.Values["action"]?.ToString();

    bool IsCurrent(string controller, string action = "") =>
        string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase)
        && (string.IsNullOrEmpty(action) || string.Equals(currentAction, action, StringComparison.OrdinalIgnoreCase));
}

<!DOCTYPE html>
<html lang="@CultureInfo.CurrentUICulture.Name">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@this.ViewData["Title"] - @CommonConstants.SystemName</title>
    <link rel="apple-touch-icon" href="~/apple-touch-icon.png"/>

    <environment names="Development">
        <link rel="stylesheet" href="~/css/style.css" asp-append-version="true" />
        <script src="~/lib/jquery/dist/jquery.js" asp-append-version="true"></script>
    </environment>
    <environment names="Staging,Production">
        <link rel="stylesheet" href="~/css/style.css" asp-append-version="true" />
        <script src="~/lib/jquery/dist/jquery.min.js" asp-append-version="true"></script>
    </environment>
</head>
<body data-show-password-text="@Localizer["PasswordToggle_Show"]" data-hide-password-text="@Localizer["PasswordToggle_Hide"]">
    <a class="skip-to-content-link" href="#app-main-content">@Localizer["Nav_SkipToContent"]</a>
    <header>
        <nav class="navbar navbar-expand-sm navbar-light site-navbar">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="fas fa-chess-knight chess-brand-icon" aria-hidden="true"></i>
                </a>
                <button class="navbar-toggler" type="button" data-toggle="collapse" data-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex flex-sm-row-reverse align-items-sm-center">
                    <partial name="_LoginPartial" />
                    <partial name="_CultureSwitcher" />
                    <ul class="navbar-nav site-navbar-main-nav flex-grow-1 align-items-sm-center">
                        <li class="nav-item">
                            <a class="nav-link @(IsCurrent("Home") ? "is-current" : string.Empty)"
                               asp-area=""
                               asp-controller="Home"
                               asp-action="Index"
                               aria-current="@(IsCurrent("Home") ? "page" : null)">
                                @Localizer["Nav_Home"]
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(IsCurrent("Game") ? "is-current" : string.Empty)"
                               asp-area=""
                               asp-controller="Game"
                               asp-action="Index"
                               aria-current="@(IsCurrent("Game") ? "page" : null)">
                                @Localizer["Nav_Play"]
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(IsCurrent("Stats") ? "is-current" : string.Empty)"
                               asp-area=""
                               asp-controller="Stats"
                               asp-action="Index"
                               aria-current="@(IsCurrent("Stats") ? "page" : null)">
                                @Localizer["Nav_Stats"]
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(IsCurrent("About") ? "is-current" : string.Empty)"
                               asp-area=""
                               asp-controller="About"
                               asp-action="Index"
                               aria-current="@(IsCurrent("About") ? "page" : null)">
                                @Localizer["Nav_About"]
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="body-renderer container">
        <partial name="_CookieConsentPartial" />
        <main role="main" id="app-main-content" class="app-main pb-3" tabindex="-1">
            @this.RenderBody()
        </main>
    </div>

    <footer class="site-footer text-muted">
        <div class="site-footer-inner">
            &copy; @DateTime.UtcNow.Year - @CommonConstants.SystemName - <i class="fab fa-github"></i> <a href="https://github.com/anton5267/Chess-master55" target="_blank">@Localizer["Footer_GitHubProject"]</a>
        </div>
    </footer>

    <environment names="Development">
        <script src="~/lib/bootstrap/dist/js/bootstrap.js" asp-append-version="true"></script>
        <script src="~/lib/jquery-validation/dist/jquery.validate.js" asp-append-version="true"></script>
        <script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.js" asp-append-version="true"></script>
        <script src="https://kit.fontawesome.com/67c59dfcad.js" asp-append-version="true" crossorigin="anonymous"></script>
    </environment>
    <environment names="Staging,Production">
        <script src="~/lib/bootstrap/dist/js/bootstrap.min.js" asp-append-version="true"></script>
        <script src="~/lib/jquery-validation/dist/jquery.validate.min.js" asp-append-version="true"></script>
        <script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js" asp-append-version="true"></script>
        <script src="https://kit.fontawesome.com/67c59dfcad.js" asp-append-version="true" crossorigin="anonymous"></script>
    </environment>
    <script src="~/js/password-toggle.js" asp-append-version="true"></script>
    <script src="~/js/form-submit-guard.js" asp-append-version="true"></script>

    @this.RenderSection("Scripts", required: false)
</body>
</html>
