@using Microsoft.AspNetCore.Localization
@using Chess.Web.Infrastructure

@{
    var currentCulture = this.Context.Features.Get<IRequestCultureFeature>()?.RequestCulture.UICulture.Name
        ?? LocalizationConstants.DefaultCulture;
    var returnUrl = $"{this.Context.Request.PathBase}{this.Context.Request.Path}{this.Context.Request.QueryString}";
}

<form asp-controller="Localization" asp-action="SetLanguage" method="post" class="form-inline culture-switcher-form">
    @Html.AntiForgeryToken()
    <input type="hidden" name="returnUrl" value="@returnUrl" />
    <select class="form-control form-control-sm culture-switcher-select" name="culture" aria-label="@Localizer["Language"]" onchange="this.form.submit()">
        @foreach (var culture in LocalizationConstants.SupportedCultures)
        {
            var isSelected = string.Equals(culture, currentCulture, System.StringComparison.OrdinalIgnoreCase);
            <option value="@culture" selected="@isSelected">@LocalizationConstants.CultureDisplayNames[culture]</option>
        }
    </select>
</form>
