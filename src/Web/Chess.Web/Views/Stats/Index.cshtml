@model Chess.Web.ViewModels.StatsViewModel

@{
    this.ViewData["Title"] = Localizer["Stats_Title"];
}

<article class="elo-rating-container">
    <section class="elo-rating-text">@Localizer["Stats_EloRating"]</section>
    <section class="elo-rating-value">@Model.UserStats.Rating</section>
</article>

<div id="piechart"></div>

<table>
    <tr class="table-title">
        <th colspan="5">@Localizer["Stats_AllUsers"]</th>
    </tr>
    <tr>
        <th class="col-title">@Localizer["Stats_TotalUsers"]</th>
        <th class="col-title">@Localizer["Stats_LastThirtyDaysUsers"]</th>
        <th class="col-title">@Localizer["Stats_TotalGames"]</th>
        <th class="col-title">@Localizer["Stats_MostGamesUser"]</th>
        <th class="col-title">@Localizer["Stats_MostWinsUser"]</th>
    </tr>
    <tr>
        <td>@Model.TotalUsers</td>
        <td>@Model.LastThirtyDaysRegisteredUsers</td>
        <td>@Model.TotalGames</td>
        <td>@Model.MostGamesUser</td>
        <td>@Model.MostWinsUser</td>
    </tr>
</table>

<script type="text/javascript" src="https://www.gstatic.com/charts/loader.js"></script>
<script type="text/javascript">
    google.charts.load('current', { 'packages': ['corechart'] });
    google.charts.setOnLoadCallback(drawChart);

    function drawChart() {
        var data = google.visualization.arrayToDataTable([
            ['@Localizer["Stats_Games"]', '@Localizer["Stats_Ending"]'],
            ['@Localizer["Stats_Wins"]', @Model.UserStats.Wins],
            ['@Localizer["Stats_Draws"]', @Model.UserStats.Draws],
            ['@Localizer["Stats_Losses"]', @Model.UserStats.Losses],
        ]);

        var options = {
            title: '@Localizer["Stats_ChartTitle", Model.UserStats.Games]',
            colors: ['#70e663', '#A9A9A9', '#2F4F4F'],
        };

        var chart = new google.visualization.PieChart(document.getElementById('piechart'));
        chart.draw(data, options);
    }
</script>
