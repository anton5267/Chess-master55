@model Chess.Web.ViewModels.StatsViewModel
@using System
@using System.Text.Json

@{
    this.ViewData["Title"] = Localizer["Stats_Title"];

    var noDataUser = Localizer["Stats_NoDataUser"].Value;
    var games = Model.UserStats.Games;
    var wins = Model.UserStats.Wins;
    var draws = Model.UserStats.Draws;
    var losses = Model.UserStats.Losses;
    var isFreshAccount = games == 0;
    var winRate = games > 0 ? Math.Round((double)wins / games * 100, 0) : 0;
    var drawRate = games > 0 ? Math.Round((double)draws / games * 100, 0) : 0;
    var lossRate = games > 0 ? Math.Round((double)losses / games * 100, 0) : 0;
    var chartPayload = new
    {
        labels = new[]
        {
            Localizer["Stats_Wins"].Value,
            Localizer["Stats_Draws"].Value,
            Localizer["Stats_Losses"].Value,
        },
        values = new[]
        {
            Model.UserStats.Wins,
            Model.UserStats.Draws,
            Model.UserStats.Losses,
        },
        title = string.Format(Localizer["Stats_ChartTitle"].Value, Model.UserStats.Games),
        emptyState = Localizer["Stats_NoGamesYet"].Value,
        colors = new[] { "#2f6fed", "#7d8ba7", "#d14d5a" },
    };

    var chartJson = JsonSerializer.Serialize(chartPayload);
    var mostGamesUser = string.IsNullOrWhiteSpace(Model.MostGamesUser) ? noDataUser : Model.MostGamesUser;
    var mostWinsUser = string.IsNullOrWhiteSpace(Model.MostWinsUser) ? noDataUser : Model.MostWinsUser;
}

<section class="stats-dashboard">
    <header class="stats-page-header" aria-labelledby="stats-page-title">
        <h1 id="stats-page-title" class="stats-page-title">@Localizer["Stats_Title"]</h1>
        <p class="stats-page-subtitle">@Localizer["Stats_AllUsers"]</p>
    </header>

    <header class="stats-hero-card">
        <div class="stats-hero-label">@Localizer["Stats_EloRating"]</div>
        <div class="stats-hero-value">@Model.UserStats.Rating</div>
        <p class="stats-hero-note">@Localizer["Stats_EloInitialHint"]</p>
    </header>

    <section class="stats-elo-note" aria-label="@Localizer["Stats_EloInfo_Title"]">
        <h2 class="stats-elo-note-title">@Localizer["Stats_EloInfo_Title"]</h2>
        <p class="stats-elo-note-text">@Localizer["Stats_EloInfo_Body"]</p>
        @if (isFreshAccount)
        {
            <p class="stats-elo-note-fresh">@Localizer["Stats_EloFreshAccountHint"]</p>
        }
    </section>

    <section class="stats-personal-grid" aria-label="@Localizer["Stats_EloRating"]">
        <article class="stats-personal-card">
            <span class="stats-personal-title">@Localizer["Stats_Games"]</span>
            <span class="stats-personal-value">@games</span>
        </article>
        <article class="stats-personal-card">
            <span class="stats-personal-title">@Localizer["Stats_Wins"]</span>
            <span class="stats-personal-value">@wins</span>
        </article>
        <article class="stats-personal-card">
            <span class="stats-personal-title">@Localizer["Stats_Draws"]</span>
            <span class="stats-personal-value">@draws</span>
        </article>
        <article class="stats-personal-card">
            <span class="stats-personal-title">@Localizer["Stats_Losses"]</span>
            <span class="stats-personal-value">@losses</span>
        </article>
    </section>

    <section class="stats-rate-strip" aria-label="@Localizer["Stats_Ending"]">
        <article class="stats-rate-card stats-rate-win">
            <span class="stats-rate-title">@Localizer["Stats_Wins"]</span>
            <strong class="stats-rate-value">@winRate%</strong>
        </article>
        <article class="stats-rate-card stats-rate-draw">
            <span class="stats-rate-title">@Localizer["Stats_Draws"]</span>
            <strong class="stats-rate-value">@drawRate%</strong>
        </article>
        <article class="stats-rate-card stats-rate-loss">
            <span class="stats-rate-title">@Localizer["Stats_Losses"]</span>
            <strong class="stats-rate-value">@lossRate%</strong>
        </article>
    </section>

    <section class="stats-balance-card" aria-label="@Localizer["Stats_Ending"]">
        <header class="stats-balance-header">
            <span class="stats-balance-title">@Localizer["Stats_Ending"]</span>
            <span class="stats-balance-total">@games @Localizer["Stats_Games"]</span>
        </header>
        <div class="stats-balance-track" role="img" aria-label="@Localizer["Stats_Ending"]">
            <span class="stats-balance-segment stats-balance-segment-win" style="width:@winRate%"></span>
            <span class="stats-balance-segment stats-balance-segment-draw" style="width:@drawRate%"></span>
            <span class="stats-balance-segment stats-balance-segment-loss" style="width:@lossRate%"></span>
        </div>
        <div class="stats-balance-legend">
            <span class="stats-balance-legend-item">
                <span class="stats-balance-dot stats-balance-dot-win" aria-hidden="true"></span>
                <span>@Localizer["Stats_Wins"]</span>
                <strong>@wins (@winRate%)</strong>
            </span>
            <span class="stats-balance-legend-item">
                <span class="stats-balance-dot stats-balance-dot-draw" aria-hidden="true"></span>
                <span>@Localizer["Stats_Draws"]</span>
                <strong>@draws (@drawRate%)</strong>
            </span>
            <span class="stats-balance-legend-item">
                <span class="stats-balance-dot stats-balance-dot-loss" aria-hidden="true"></span>
                <span>@Localizer["Stats_Losses"]</span>
                <strong>@losses (@lossRate%)</strong>
            </span>
        </div>
    </section>

    <section class="stats-kpi-grid" aria-label="@Localizer["Stats_AllUsers"]">
        <article class="stats-kpi-card">
            <span class="stats-kpi-title">@Localizer["Stats_TotalUsers"]</span>
            <span class="stats-kpi-value">@Model.TotalUsers</span>
        </article>
        <article class="stats-kpi-card">
            <span class="stats-kpi-title">@Localizer["Stats_LastThirtyDaysUsers"]</span>
            <span class="stats-kpi-value">@Model.LastThirtyDaysRegisteredUsers</span>
        </article>
        <article class="stats-kpi-card">
            <span class="stats-kpi-title">@Localizer["Stats_TotalGames"]</span>
            <span class="stats-kpi-value">@Model.TotalGames</span>
        </article>
        <article class="stats-kpi-card">
            <span class="stats-kpi-title">@Localizer["Stats_MostGamesUser"]</span>
            <span class="stats-kpi-value">@mostGamesUser</span>
        </article>
        <article class="stats-kpi-card">
            <span class="stats-kpi-title">@Localizer["Stats_MostWinsUser"]</span>
            <span class="stats-kpi-value">@mostWinsUser</span>
        </article>
    </section>

    <section class="stats-chart-card" aria-labelledby="stats-chart-title">
        <figure class="stats-chart-figure">
            <figcaption id="stats-chart-title" class="stats-chart-title">@Localizer["Stats_ChartTitle", Model.UserStats.Games]</figcaption>
            <canvas id="stats-pie-chart" role="img" aria-label="@Localizer["Stats_ChartTitle", Model.UserStats.Games]"></canvas>
            <p id="stats-chart-empty" class="stats-chart-empty" hidden>@Localizer["Stats_NoGamesYet"]</p>
        </figure>
    </section>
</section>

<script id="stats-data" type="application/json">@Html.Raw(chartJson)</script>

@section Scripts
{
    <environment names="Development">
        <script src="~/js/stats.bundle.js" asp-append-version="true"></script>
    </environment>
    <environment names="Staging,Production">
        <script src="~/js/stats.bundle.min.js" asp-append-version="true"></script>
    </environment>
}
