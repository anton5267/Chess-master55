@{
    this.ViewData["Title"] = Localizer["Home_Title"];
}

<section class="home-hero">
    <div class="home-hero-content">
        <p class="home-hero-kicker">@Localizer["Home_Title"]</p>
        <h1 class="home-hero-title">Chess</h1>
        <p class="home-hero-subtitle">@Localizer["Home_HistoryParagraph1"]</p>
        <div class="home-hero-actions">
            <a class="btn btn-primary home-hero-btn" asp-controller="Game" asp-action="Index">@Localizer["Home_CardPlayTitle"]</a>
            <a class="btn btn-outline-primary home-hero-btn" asp-controller="Stats" asp-action="Index">@Localizer["Home_CardStatsTitle"]</a>
        </div>
    </div>
    <aside class="home-hero-meta">
        <h2 class="home-hero-meta-title">@Localizer["Home_CardAboutTitle"]</h2>
        <ul class="home-hero-meta-list">
            <li>
                <i class="fas fa-bolt" aria-hidden="true"></i>
                <span>@Localizer["Home_CardPlayDescription"]</span>
            </li>
            <li>
                <i class="fas fa-chart-line" aria-hidden="true"></i>
                <span>@Localizer["Home_CardStatsDescription"]</span>
            </li>
            <li>
                <i class="fas fa-circle-info" aria-hidden="true"></i>
                <span>@Localizer["Home_CardAboutDescription"]</span>
            </li>
        </ul>
    </aside>
</section>

<section class="home-summary-strip" aria-label="@Localizer["Home_Title"]">
    <article class="home-summary-card">
        <div class="home-summary-icon" aria-hidden="true"><i class="fas fa-play"></i></div>
        <h2 class="home-summary-title">@Localizer["Home_CardPlayTitle"]</h2>
        <p class="home-summary-text">@Localizer["Home_CardPlayDescription"]</p>
        <a class="home-summary-link" asp-controller="Game" asp-action="Index">@Localizer["Nav_Play"]</a>
    </article>
    <article class="home-summary-card">
        <div class="home-summary-icon" aria-hidden="true"><i class="fas fa-chart-bar"></i></div>
        <h2 class="home-summary-title">@Localizer["Home_CardStatsTitle"]</h2>
        <p class="home-summary-text">@Localizer["Home_CardStatsDescription"]</p>
        <a class="home-summary-link" asp-controller="Stats" asp-action="Index">@Localizer["Nav_Stats"]</a>
    </article>
    <article class="home-summary-card">
        <div class="home-summary-icon" aria-hidden="true"><i class="fas fa-circle-info"></i></div>
        <h2 class="home-summary-title">@Localizer["Home_CardAboutTitle"]</h2>
        <p class="home-summary-text">@Localizer["Home_CardAboutDescription"]</p>
        <a class="home-summary-link" asp-controller="About" asp-action="Index">@Localizer["Nav_About"]</a>
    </article>
</section>

<section class="home-feature-grid">
    <article class="home-feature-card">
        <div class="home-feature-image-wrap">
            <img class="home-feature-image" src="~/img/chess.jpg" alt="@Localizer["Home_PlayImageAlt"]">
        </div>
        <div class="home-feature-body">
            <h3 class="home-feature-title">
                <a asp-controller="Game" asp-action="Index"><i class="fas fa-play"></i> @Localizer["Home_CardPlayTitle"]</a>
            </h3>
            <p class="home-feature-description">@Localizer["Home_CardPlayDescription"]</p>
        </div>
    </article>

    <article class="home-feature-card">
        <div class="home-feature-image-wrap">
            <img class="home-feature-image" src="~/img/image2.jpg" alt="@Localizer["Home_StatsImageAlt"]">
        </div>
        <div class="home-feature-body">
            <h3 class="home-feature-title">
                <a asp-controller="Stats" asp-action="Index"><i class="fas fa-chart-bar"></i> @Localizer["Home_CardStatsTitle"]</a>
            </h3>
            <p class="home-feature-description">@Localizer["Home_CardStatsDescription"]</p>
        </div>
    </article>

    <article class="home-feature-card">
        <div class="home-feature-image-wrap">
            <img class="home-feature-image" src="~/img/image3.jpg" alt="@Localizer["Home_AboutImageAlt"]">
        </div>
        <div class="home-feature-body">
            <h3 class="home-feature-title">
                <a asp-controller="About" asp-action="Index"><i class="fas fa-info-circle"></i> @Localizer["Home_CardAboutTitle"]</a>
            </h3>
            <p class="home-feature-description">@Localizer["Home_CardAboutDescription"]</p>
        </div>
    </article>
</section>

<section class="home-history-card">
    <h2 class="home-history-title">@Localizer["Home_Title"]</h2>
    <p class="home-history-text">@Localizer["Home_HistoryParagraph1"]</p>
    <p class="home-history-text">@Localizer["Home_HistoryParagraph2"]</p>
</section>
