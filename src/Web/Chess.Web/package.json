{
  "name": "chess-web-assets",
  "private": true,
  "devDependencies": {
    "esbuild": "^0.25.0"
  },
  "scripts": {
    "build:js": "esbuild wwwroot/js/src/game.js --bundle --format=iife --outfile=wwwroot/js/game.bundle.js --sourcemap",
    "build:js:min": "esbuild wwwroot/js/src/game.js --bundle --format=iife --minify --outfile=wwwroot/js/game.bundle.min.js",
    "build:assets": "npm run build:js && npm run build:js:min"
  }
}
