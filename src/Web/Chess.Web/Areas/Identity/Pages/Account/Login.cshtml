@page
@model LoginModel

@{
    ViewData["Title"] = Localizer["Id_LoginTitle"];
}

<section class="auth-shell">
    <header class="auth-shell-header">
        <h1>@ViewData["Title"]</h1>
    </header>
<div class="row auth-shell-row auth-shell-content">
    <div class="col-lg-6 col-md-6">
        <section class="auth-panel auth-panel-primary">
            <form id="account" method="post">
                <h2>@Localizer["Id_LoginSubtitle"]</h2>
                <hr />
                <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
                <div class="form-floating mb-3">
                    <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="@Localizer["Id_EmailPlaceholder"]" />
                    <label asp-for="Input.Email" class="form-label">@Localizer["Id_Email"]</label>
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>
                <div class="form-floating mb-3">
                    <input asp-for="Input.Password" class="form-control" autocomplete="current-password" aria-required="true" placeholder="@Localizer["Id_PasswordPlaceholder"]" />
                    <label asp-for="Input.Password" class="form-label">@Localizer["Id_Password"]</label>
                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                </div>
                <div class="auth-remember-me mb-3">
                    <input class="auth-remember-input" asp-for="Input.RememberMe" />
                    <label asp-for="Input.RememberMe" class="auth-remember-label">
                        @Html.DisplayNameFor(m => m.Input.RememberMe)
                    </label>
                </div>
                <div>
                    <button id="login-submit" type="submit" class="w-100 btn btn-lg btn-primary">@Localizer["Id_LoginButton"]</button>
                </div>
                <div class="auth-links-list">
                    <p>
                        <a id="forgot-password" asp-page="./ForgotPassword">@Localizer["Id_ForgotPassword"]</a>
                    </p>
                    <p>
                        <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">@Localizer["Id_RegisterAsNew"]</a>
                    </p>
                    <p>
                        <a id="resend-confirmation" asp-page="./ResendEmailConfirmation">@Localizer["Id_ResendConfirmation"]</a>
                    </p>
                </div>
            </form>
        </section>
    </div>
    <div class="col-lg-6 col-md-6">
        <section class="auth-panel auth-panel-muted auth-panel-external">
            <h3>@Localizer["Id_LoginExternalTitle"]</h3>
            <hr />
            @{
                if ((Model.ExternalLogins?.Count ?? 0) == 0)
                {
                    <div>
                        <p>
                            @Localizer["Id_NoExternalLoginProviders"] <a href="https://go.microsoft.com/fwlink/?LinkID=532715">@Localizer["Id_ExternalArticleLinkText"]</a>.
                        </p>
                    </div>
                }
                else
                {
                    <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post" class="form-horizontal">
                        <div>
                            <p>
                                @foreach (var provider in Model.ExternalLogins!)
                                {
                                    <button type="submit" class="btn btn-primary" name="provider" value="@provider.Name" title="@Localizer["Id_LoginUsingProvider", provider.DisplayName]">@provider.DisplayName</button>
                                }
                            </p>
                        </div>
                    </form>
                }
            }
        </section>
    </div>
</div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
