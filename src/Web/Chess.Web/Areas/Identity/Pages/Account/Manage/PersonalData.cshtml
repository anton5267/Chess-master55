@page
@model PersonalDataModel
@{
    ViewData["Title"] = Localizer["Manage_PersonalDataTitle"];
    ViewData["ActivePage"] = ManageNavPages.PersonalData;
}

<h3>@ViewData["Title"]</h3>

<div class="row">
    <div class="col-md-6">
        <p>@Localizer["Manage_PersonalDataDescription"]</p>
        <p>
            <strong>@Localizer["Manage_DeleteDataWarning"]</strong>
        </p>
        <form id="download-data" asp-page="DownloadPersonalData" method="post">
            <button class="btn btn-primary" type="submit">@Localizer["Manage_DownloadButton"]</button>
        </form>
        <p>
            <a id="delete" asp-page="DeletePersonalData" class="btn btn-danger">@Localizer["Manage_DeleteButton"]</a>
        </p>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
