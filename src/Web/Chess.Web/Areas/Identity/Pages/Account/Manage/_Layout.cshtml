@{
    if (ViewData.TryGetValue("ParentLayout", out var parentLayout) && parentLayout != null)
    {
        Layout = parentLayout.ToString();
    }
    else
    {
        Layout = "/Areas/Identity/Pages/_Layout.cshtml";
    }
}

<section class="manage-shell">
    <header class="manage-shell-header">
        <div>
            <h1 class="manage-shell-title">@Localizer["Manage_AccountTitle"]</h1>
            <p class="manage-shell-subtitle">@Localizer["Manage_AccountSubtitle"]</p>
        </div>
        <div class="manage-user-chip">
            <i class="fas fa-user-circle" aria-hidden="true"></i>
            <span>@(this.User?.Identity?.Name ?? Localizer["Manage_Profile"])</span>
        </div>
    </header>

    <div class="manage-shell-content">
        <aside class="manage-nav-card">
            <partial name="_ManageNav" />
        </aside>
        <section class="manage-content-card">
            @RenderBody()
        </section>
    </div>
</section>

@section Scripts {
    @RenderSection("Scripts", required: false)
}
