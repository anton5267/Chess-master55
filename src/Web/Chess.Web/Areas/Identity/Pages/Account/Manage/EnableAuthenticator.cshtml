@page
@model EnableAuthenticatorModel
@{
    ViewData["Title"] = Localizer["Manage_EnableAuthenticatorTitle"];
    ViewData["ActivePage"] = ManageNavPages.TwoFactorAuthentication;
}

<partial name="_StatusMessage" for="StatusMessage" />
<h3>@ViewData["Title"]</h3>
<div>
    <p>@Localizer["Manage_EnableAuthenticatorIntro"]</p>
    <ol class="list">
        <li>
            <p>
                @Localizer["Manage_EnableAuthenticatorStep1"]
                <a href="https://go.microsoft.com/fwlink/?Linkid=825072">@Localizer["Manage_Android"]</a>
                @Localizer["Manage_And"]
                <a href="https://go.microsoft.com/fwlink/?Linkid=825073">@Localizer["Manage_iOS"]</a>
                @Localizer["Manage_Or"]
                <a href="https://play.google.com/store/apps/details?id=com.google.android.apps.authenticator2&amp;hl=en">@Localizer["Manage_Android"]</a>
                @Localizer["Manage_And"]
                <a href="https://itunes.apple.com/us/app/google-authenticator/id388497605?mt=8">@Localizer["Manage_iOS"]</a>.
            </p>
        </li>
        <li>
            <p>@Localizer["Manage_EnableAuthenticatorStep2", Model.SharedKey]</p>
            <div class="alert alert-info">@Localizer["Manage_LearnHowTo"] <a href="https://go.microsoft.com/fwlink/?Linkid=852423">@Localizer["Manage_EnableQrCodeGeneration"]</a>.</div>
            <div id="qrCode"></div>
            <div id="qrCodeData" data-url="@Model.AuthenticatorUri"></div>
        </li>
        <li>
            <p>
                @Localizer["Manage_EnableAuthenticatorStep3"]
            </p>
            <div class="row">
                <div class="col-md-6">
                    <form id="send-code" method="post">
                        <div class="form-floating mb-3">
                            <input asp-for="Input.Code" class="form-control" autocomplete="off" placeholder="@Localizer["Manage_VerificationCodePlaceholder"]" />
                            <label asp-for="Input.Code" class="control-label form-label">@Localizer["Manage_VerificationCode"]</label>
                            <span asp-validation-for="Input.Code" class="text-danger"></span>
                        </div>
                        <button type="submit" class="w-100 btn btn-lg btn-primary">@Localizer["Manage_VerifyButton"]</button>
                        <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
                    </form>
                </div>
            </div>
        </li>
    </ol>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
